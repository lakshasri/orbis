#!/usr/bin/env bash
set -euo pipefail

msg_file="$1"
subject="$(head -n 1 "$msg_file" | tr -d '\r')"

# Enforce short subject line.
max_len=50
if [ "${#subject}" -gt "$max_len" ]; then
  echo "commit message too long: ${#subject} chars (max ${max_len})"
  echo "use a shorter, lowercase subject"
  exit 1
fi

# Enforce lowercase subject.
if [ "$subject" != "${subject,,}" ]; then
  echo "commit message must be lowercase"
  echo "example: chore: add api config"
  exit 1
fi
